@model List<OnlineNews.Models.Database.Article>



@{
    ViewData["Title"] = "GetAllArticles";
}

<h2>@ViewData["Title"]</h2>

<div>
    <a href="@Url.Action("GetAllArticles", "Editor", new { showRejected = false })">Show Approved Articles</a> |
    <a href="@Url.Action("GetAllArticles", "Editor", new { showRejected = true })">Show Rejected Articles</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Content</th>
            
            <th>Headline</th>
            <th>ChosenCategory</th>
            <th>EditorsChoice</th>
            <th>Approval Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var article in Model)
        {
            <tr>
                <td>@article.Id</td>
                <td>@article.Content</td>
                <td>@article.Headline</td>
                <td>@article.ChosenCategory</td>
                <td>@article.EditorsChoice</td>
                <td>
                    @if (article.ApprovalStatus == "Approved")
                    {
                        <span class="text-success">Approved</span>
                    }
                    else if(article.ApprovalStatus == "Rejected")
                    {
                        <span class="text-warning">Rejected</span>
                    }
                    else
                    {
                        <span class="text-warning">Pending</span>
                    }
                </td>
                 <td>
    <form method="post" action="@Url.Action("GetAllArticles", "Editor", new { id = article.Id })" style="display:inline;">
        @Html.AntiForgeryToken() 
        <select name="status" class="form-control" onchange="this.form.submit()">

            Pending
            Approved
            Rejected
        </select>
    </form>
</td>
            </tr>
        }
    </tbody>
</table>
