@model IEnumerable<OnlineNews.Models.Database.Article>


@{
    ViewData["Title"] = "Search Result";
    var searchResults = ViewBag.msg as string; 
}

<br />
<br />
<br />
<h3 class="text-center" style="color:blue;">Your search results:  <b style="color:green">  @searchResults</b></h3>

<div class="row justify-content-center">
   <div class="col-md-10">
      <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 m-3" style="position:-webkit-sticky">
                <partial name="_EditorsPartial" model="@item" />
            </div>
        }
      </div>
   </div>
</div>
