@model IEnumerable<OnlineNews.Models.Database.Article>

@{
    ViewData["Title"] = "SearchResult";
}

@{
    var searchresults = ViewData["Searchresultsbysearchbar"];
}


<br />
<br />
<br/>
<h3 style="text-align:center">Your search results:@searchresults</h3>

<div class="row justify-content-center">


   <div class="col-md-10">

      <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-3 m-3">
                <partial name="_EditorsPartial" model="item" />
            </div>
        }
     </div>
   </div>
</div>
