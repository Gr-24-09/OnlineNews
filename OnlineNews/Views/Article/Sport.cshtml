@model IEnumerable<OnlineNews.Models.Database.Article>


@{
    ViewData["Title"] = "Sport";
}
<h2 style="color:blue">Sports News</h2>

<br />
<br />

<div class="row text-center">
    <div class="col-sm-10">
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-3 m-3">
                    <partial name="_ArticlePartial" model="item" />
                </div>
            }
        </div>
    </div>
</div>

