@model OnlineNews.Models.Database.Article


@{
    ViewData["Title"] = "Details";
}

<br />
<br />
<div class="container-fluid">
    <div class="row">
        <div class="row">
            <h1 class="row justify-content-center">
                @Model.Headline
            </h1>
        </div>
    </div>
</div>
<br />
<br />
<br />
<div class="container">
    <div class="row">
        <em>@Model.PublishedDate</em>
    </div>
</div>
<br />
<div class="container">
    <div class="rounded max-auto d-block img">
        <div>
            <img src="@Model.ImageLink" style="width:700px;height:400px"/>
        </div>
    </div>
</div>
<br />
<br />
<br />
<div class="row">
    @Model.Content
</div>
<p><b>Likes:</b>@Model.Likes</p><p><b><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#0000F5"><path d="M480-320q75 0 127.5-52.5T660-500q0-75-52.5-127.5T480-680q-75 0-127.5 52.5T300-500q0 75 52.5 127.5T480-320Zm0-72q-45 0-76.5-31.5T372-500q0-45 31.5-76.5T480-608q45 0 76.5 31.5T588-500q0 45-31.5 76.5T480-392Zm0 192q-146 0-266-81.5T40-500q54-137 174-218.5T480-800q146 0 266 81.5T920-500q-54 137-174 218.5T480-200Zm0-300Zm0 220q113 0 207.5-59.5T832-500q-50-101-144.5-160.5T480-720q-113 0-207.5 59.5T128-500q50 101 144.5 160.5T480-280Z" /></svg></b>@Model.Views</p>
<div>
    @using (Html.BeginForm("LikeAnArticle", "Article", new { id = Model.Id }, FormMethod.Post))
    {
       <button value="submit"><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#0000F5"><path d="M720-120H280v-520l280-280 50 50q7 7 11.5 19t4.5 23v14l-44 174h258q32 0 56 24t24 56v80q0 7-2 15t-4 15L794-168q-9 20-30 34t-44 14Zm-360-80h360l120-280v-80H480l54-220-174 174v406Zm0-406v406-406Zm-80-34v80H160v360h120v80H80v-520h200Z" /></svg></button>
    }
    <br />
    @using (Html.BeginForm("DisLikeAnArticle", "Article", new { id = Model.Id }, FormMethod.Post))
    {
       <button value="submit"><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#0000F5"><path d="M240-840h440v520L400-40l-50-50q-7-7-11.5-19t-4.5-23v-14l44-174H120q-32 0-56-24t-24-56v-80q0-7 2-15t4-15l120-282q9-20 30-34t44-14Zm360 80H240L120-480v80h360l-54 220 174-174v-406Zm0 406v-406 406Zm80 34v-80h120v-360H680v-80h200v520H680Z" /></svg></button>
    }
</div>
<hr />