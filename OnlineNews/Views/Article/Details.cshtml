@model OnlineNews.Models.Database.Article


@{
    ViewData["Title"] = "Details";
}

<br />
<br />
<div class="container-fluid">
    <div class="row">
        <div class="row">
            <h1 class="row justify-content-center">
                @Model.Headline
            </h1>

        </div>

    </div>
</div>
<br />
<br />
<br />
<div class="container">
    <div class="row">
        <em>@Model.PublishedDate</em>
    </div>
</div>
<br />
<div class="container">
    <div class="rounded max-auto d-block img">
        <div>
            <img src="@Model.ImageLink" style="width:700px;height:400px"/>
        </div>
    </div>
</div>
<br />
<br />
<br />

<div class="row">
    @Model.Content
</div>

