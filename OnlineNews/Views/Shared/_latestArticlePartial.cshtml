@model OnlineNews.Models.Database.Article

<div class="card border-white mb-3">

  <div class="row">
        <img src="@Model.ImageLink" class="card-img-top" style="width:520px;height:310px" />
        <div class="card-body">
            <h2 class="card-title">@Model.Headline</h2>
            <a style="color:black;text-decoration-line: none" asp-action="Details" asp-controller="Article" asp-route-id="@Model.Id"><p>@Model.ContentSummary</p></a>
        </div>
  </div>
</div>

