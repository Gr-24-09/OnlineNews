@model OnlineNews.Models.API.WeatherForecast

<a href="@Url.Action("Weather", "Home")" class="weather-widget d-flex align-items-center" style="text-decoration: none; color: inherit;">
    
    <img src="@Model.icon?.url" alt="@Model.summary" style="width: 24px; height: 24px; margin-right: 8px;" />
    
    <div>
        <h5 style="font-size: 14px; margin-bottom: 0;">@Model.city</h5>
        <p style="font-size: 12px; margin-bottom: 0;">
            @Model.temperatureC °C
        </p>
    </div>
</a>
