@model OnlineNews.Models.Database.Article


<div class="card">

    <img src="@Model.ImageLink" class="card-img-top" style="width:500px;height:300px" />

    <div class="card-body">
        <h2 class="card-title">@Model.Headline</h2>
        <a class="bg-primary" style="text-decoration-line: none" asp-action="Details" asp-controller="Article" asp-route-id="@Model.Id"><p>@Model.ContentSummary</p></a>
    </div>
</div>