@model OnlineNews.Models.Database.Article


<div class="card">

    <img src="@Model.ImageLink" class="card-img-top" />

    <div class="card-body">

        <h4 class="card-title">@Model.Headline</h4>
        @* <p class="card-text">@Model.Headline</p> *@
        <a class="bg-primary" asp-action="Details" asp-controller="Article" asp-route-id="@Model.Id"><p>@Model.ContentSummary</p></a>
    </div>
</div>