<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OnlineNews</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OnlineNews.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Abril+Fatface" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
      <header>
           <div class="row allfont" style="border:1px solid blue">
            <nav class="navbar navbar-expand-sm  d-flex justify-content-center bg-primary navbar-primary">
                <div class="container-fluid justify-content-center" style="font-size:20px">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index" style="color:white;">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Create" style="color:white;">Add product</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Product" asp-action="AllProducts" style="color:white;">List of Products</a>
                        </li>
                        <li>
                            <form asp-Controller="Product" asp-action="SearchResult" class="d-flex gap-3">
                                <label for="searchitem" class="sr-only"></label>
                                <input type="text" name="searchitem" id="searchitem" class="searchBar form-control" placeholder="Search by Product,Category..." />
                                <button class="searchBtn btn btn-primary" type="submit">
                                    <svg xmlns="http://www.w3.org/2000/svg" height="30px" viewBox="0 -960 960 960" width="30px" fill="#fff">
                                        <path d="M784-120 532-372q-30 24-69 38t-83 14q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l252 252-56 56ZM380-400q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z" />
                                    </svg>
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </nav>
        </div>
      </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="bg-primary text-white pt-5 pb-2">
        <div class="text-center">
            © 2025 Copyright  <a asp-area="" asp-controller="Product" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>
</body>
</html>
