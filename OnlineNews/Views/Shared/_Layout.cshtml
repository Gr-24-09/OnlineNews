    footer {
        background-color: #1c2331;
        color: white;
    }

    .footer h6 {
        font-size: 1.2rem;
        font-weight: bold;
        text-transform: uppercase;
        margin-bottom: 1rem;
    }

    .footer p {
        font-size: 1rem;
        line-height: 1.5;
    }

    .footer a {
        color: #ffffff;
        text-decoration: none;
    }

    .footer a:hover {
        color: #d1d1d1;
    }

    .footer i {
        color: #ffffff;
    }

    .footer .fab {
        font-size: 1.5rem;
        transition: color 0.3s ease;
    }

    .footer .fab:hover {
        color: #7c4dff;
    }

    .footer-copyright {
        background-color: #23272b;
        color: #ffffff;
        font-size: 0.9rem;
    }

   {
        .footer .container {
            padding-left: 0;
            padding-right: 0;
        }

        .footer .row {
            text-align: center;
        }

        .footer .col-md-3, .footer .col-md-2, .footer .col-md-4 {
            margin-bottom: 2rem;
        }

        .footer .fab {
            font-size: 1.2rem;
        }
    }

    body {
        padding-bottom: 80px;
    }
</style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
