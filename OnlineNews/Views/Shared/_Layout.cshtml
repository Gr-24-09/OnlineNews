@using OnlineNews.Service
@inject ICategoryService _categoryService;

@{
    var categoryList = _categoryService.GetAllCategory();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OnlineNews</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OnlineNews.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
       @*  Advertisement *@
        <div class="row borderbar"></div>
        <div class="col-lg-12 col-md-12 col-sm-12 col-12 card mt-2 mb-2 text-center border-white">
            <div class="row">
                <div class="row">
                    <a href="https://se.cec.com/inbyte?gad_source=5&gclid=EAIaIQobChMI7YTrvoHViwMVEV0eAh0-nD0wEAEYASAAEgKF-vD_BwE" target="_blank" class="text-white  mx-2" aria-label="Advertisement">
                        <img src="https://tpc.googlesyndication.com/simgad/16690010714385765024?sqp=4sqPyQQrQikqJwhfEAEdAAC0QiABKAEwCTgDQPCTCUgAUAFYAWBfcAJ4AcUBLbKdPg&rs=AOga4qlUYEOEG3j53WZzb07D7fp1nYf5BQ" style="width:auto;" />
                    </a>
                </div>
            </div>
        </div>
            <nav class="navbar navbar-expand-lg navbar-toggleable-sm secondLine">
                <div class="container-fluid dropdwnSearch">
                    <div class="collapse navbar-collapse ms-auto" id="navbarNavDarkDropdown">
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link" style="font-size:30px" id="navbarDarkDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    ☰
                                </a>
                                <ul class="dropdown-menu bg-light flex-column" style="font-size:20px; border:2px solid #234;" aria-labelledby="navbarDarkDropdownMenuLink">
                                    @foreach (var item in categoryList)
                                    {
                                        <li class="nav-item">
                                        <a class="nav-link" style="color:blue;" asp-area="" asp-controller="Article" asp-action="CategoryNews" asp-route-id="@item.Id">@item.Name</a>
                                        </li>
                                    }
                                    <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Article" asp-action="Index" style="color:blue;">All Articles</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="EditorsChoiced">Editor's Choice</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" asp-area="" asp-controller="Article" asp-action="ArchivedArticles">Archived Articles</a>
                                    </li>
                                    <li>
                                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="WeatherSearch" style="color:blue;">Weather Forecast</a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                        <form asp-Controller="Article" asp-action="SearchResult" class="d-flex align-items-center gap-3">
                            <label for="searchitem"></label>
                            <input type="text" name="searchitem" id="searchitem" class="searchBar" placeholder="Search here by category......" />
                            <button class="searchBtn" style="margin-left:-20px" type="submit"><svg xmlns="http://www.w3.org/2000/svg" height="30px" viewBox="0 -960 960 960" width="30px" fill="#0000F5"><path d="M784-120 532-372q-30 24-69 38t-83 14q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l252 252-56 56ZM380-400q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z" /></svg></button>
                        </form>
                    </div>
                    <a class="navbar-brand" style="font-family:fantasy;font-size:60px;color: blue;" asp-area="" asp-controller="Home" asp-action="Index">ASAM</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse justify-content-xl-end">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>
        <div class="row">
            <nav class="navbar navbar-expand-sm  d-flex justify-content-center bg-primary-subtle navbar-primary">
                <div class="container-fluid justify-content-center" style="font-size:20px">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" style="color:blue;">Home</a>
                        </li>
                        @foreach (var item in categoryList)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Article" asp-action="CategoryNews" asp-route-id="@item.Id" style="color:blue;">@item.Name</a>
                            </li>
                        }
                        <li>
                             <a class="nav-link" asp-area="" asp-controller="Home" asp-action="WeatherSearch" style="color:blue;">Weather Forecast</a>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                        { 
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Admin page
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">

                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="ListUsers">Manage users</a></li>
                                    
                                </ul>
                            </li>

                            
                        }

                        @if (User.IsInRole("Editor"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Editor's page
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <li><a class="dropdown-item" asp-controller="Article" asp-action="AddArticle">Add articles</a></li>
                                    @* <li><a class="dropdown-item" asp-controller="Editor" asp-action="ApproveArticle">Approve articles</a></li> *@
                                    <li><a class="dropdown-item" asp-controller="Editor" asp-action="GetAllArticles">Approve articles</a></li>
                                    @* <li><a class="dropdown-item" href="#">Approve Articles</a></li> *@
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Writer"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Writer's page
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <li class="nav-item">
                                        <a class="dropdown-item" asp-area="" asp-controller="Article" asp-action="AddArticle">Add Article</a>
                                    </li>
                                    <li class="dropdown-item">
                                        <a class="nav-link" asp-area="" asp-controller="Category" asp-action="Create">Add Category</a>
                                    </li>
                                </ul>
                            </li>
                        } 
                    </ul>
                </div>
            </nav>
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody() <!-- Page content -->
        </main>
    </div>
        @* <footer class="footer text-muted bg-primary-subtle">
                <b style="color:blue;font-size:30px;">ASAM</b>
                   <nav class="navbar navbar-expand-sm  d-flex justify-content-center bg-primary-subtle navbar-primary">
                      <div class="container-fluid justify-content-center" style="color:blue;font-size:20px">
                           <ul class="navbar-nav">
                              <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                              </li>
                              @foreach (var item in categoryList)
                              {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Article" asp-action="CategoryNews" asp-route-id="@item.Id">@item.Name</a>
                                </li>
                              }
                              <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                           </ul>
                      </div>
                   </nav>
        </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
