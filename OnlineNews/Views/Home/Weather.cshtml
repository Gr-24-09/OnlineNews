@model IEnumerable<OnlineNews.Models.API.WeatherForecast>

@{
    ViewData["Title"] = "Weather Forecasts";
}

<div class="weather-container">
    @foreach (var forecast in Model)
    {
        <div class="weather-details">
            <h1>@forecast.city</h1>
            <img src="@forecast.icon?.url" alt="Weather icon" />
            <h3>Weather Forecast</h3>
            <p><strong>Temperature:</strong> @forecast.temperatureC °C (@forecast.temperatureF °F)</p>
            <p><strong>Humidity:</strong> @forecast.humidity %</p>
            <p><strong>Wind Speed:</strong> @forecast.windSpeed km/h</p>
            <p><strong>Summary:</strong> @forecast.summary</p>
            <p><strong>Time:</strong> @forecast.date</p>
        </div>
    }
</div>

<style>
    .weather-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
    }

    .weather-details {
        text-align: center;
        padding: 20px;
        background-color: #ffffff;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        max-width: 300px;
        transition: all 0.3s ease-in-out;
    }

        .weather-details img {
            width: 100px;
            height: 100px;
            margin-bottom: 10px;
        }

        .weather-details h1 {
            font-size: 24px;
            color: #0056b3;
        }
</style>
