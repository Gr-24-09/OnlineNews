@model OnlineNews.Models.API.WeatherForecast

@{
    ViewData["Title"] = "Weather Forecast";
}

<div class="weather-details">
    <h1>@Model.city</h1>
    <img src="@Model.icon?.url" alt="Weather icon" />
    <h3>Weather Forecast</h3>
    <p><strong>Temperature:</strong> @Model.temperatureC °C (@Model.temperatureF °F)</p>
    <p><strong>Humidity:</strong> @Model.humidity %</p>
    <p><strong>Wind Speed:</strong> @Model.windSpeed km/h</p>
    <p><strong>Summary:</strong> @Model.summary</p>
    <p><strong>Time:</strong> @Model.date</p>
    <a href="/" class="back-button">Back to Home</a>
</div>

<style>
  
    .weather-details {
        text-align: center;
        margin-top: 50px;
        padding: 30px;
        background-color: #ffffff;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
        transition: all 0.3s ease-in-out; 
    }

    .weather-details img {
        width: 130px;
        height: 130px;
        margin-bottom: 20px;
        border-radius: 15px;
        border: 1px solid #ddd;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease-in-out;
    }

    .weather-details img:hover {
        transform: scale(1.1); 
    }

  
    .weather-details h1 {
        font-size: 38px;
        color: #0056b3;
        margin-bottom: 15px;
        font-weight: 600;
    }

    .weather-details h3 {
        font-size: 28px;
        color: #6c757d;
        margin-bottom: 20px;
    }

    .weather-details p {
        font-size: 18px;
        margin-bottom: 12px;
        color: #333;
    }
    .weather-details .temperature {
        font-size: 26px;
        font-weight: bold;
        color: #ff5733; 
    }

    .weather-details .back-button {
        padding: 12px 24px;
        font-size: 18px;
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        margin-top: 30px;
        transition: background-color 0.3s ease;
    }

    .weather-details .back-button:hover {
        background-color: aqua; 
    }

    {
        .weather-details {
            padding: 20px;
            max-width: 95%;
            font-size: 14px;
        }

        .weather-details h1 {
            font-size: 30px;
        }

        .weather-details h3 {
            font-size: 24px; 
        }

        .weather-details p {
            font-size: 16px; 
        }

        .weather-details .temperature {
            font-size: 22px;
        }

        .weather-details .back-button {
            font-size: 16px; 
        }

        .weather-details img {
            width: 100px;
            height: 100px;
        }
    }
</style>
