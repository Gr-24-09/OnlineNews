                            <strong>Price (SEK):</strong> @price.price_sek <br />
                            <strong>KMeans:</strong> @price.kmeans
                        </li>
                    }
                </ul>
            }
            else
            {
                <p>No data available.</p>
            }
        </div>

        <div class="col-md-3">
            <h3>SE4</h3>
            @if (Model.SE4 != null && Model.SE4.Any())
            {
                <ul class="list-group">
