            }
            @if (User.IsInRole("Writer"))
            {
                <a class="dropdown-item" asp-area="" asp-controller="Article" asp-action="EditAsWriter" asp-route-id="@item.Id"><svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#0000F5"><path d="M80 0v-160h800V0H80Zm160-320h56l312-311-29-29-28-28-311 312v56Zm-80 80v-170l448-447q11-11 25.5-17t30.5-6q16 0 31 6t27 18l55 56q12 11 17.5 26t5.5 31q0 15-5.5 29.5T777-687L330-240H160Zm560-504-56-56 56 56ZM608-631l-29-29-28-28 57 57Z" /></svg></a>
            }
        }
        <div class="row electricity">
            @await Component.InvokeAsync("ElectricityPrices")
        </div>
    </div>
</div>
<div class="row justify-content-center allfont mt-0">
    <div class="col-lg-12 col-md-12 col-sm-12">
        <div class="row justify-content-center">
            @foreach (var item in Model.SomeLatestNews.Skip(7))
            {
                <div class="col-12 col-md-6 col-lg-3 mb-3">
                    <!-- Responsive: Full-width on small screens, 2 per row on medium, 4 per row on large -->
                    <partial name="_EditorsPartial" model="@item" />

                    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                    {
                        <a asp-action="Edit" asp-controller="Article" asp-route-id="@item.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#0000F5">
                                <path d="M200-200h57l391-391-57-57-391 391v57Zm-80 80v-170l528-527q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L290-120H120Zm640-584-56-56 56 56Zm-141 85-28-29 57 57-29-28Z" />
                            </svg>
                        </a>
                        <a asp-action="Delete" asp-controller="Article" asp-route-id="@item.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#5D0E07">
                                <path d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z" />
                            </svg>
                        </a>
                    }
                    @if (User.IsInRole("Writer"))
                    {
                        <a class="dropdown-item" asp-area="" asp-controller="Article" asp-action="EditAsWriter" asp-route-id="@item.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#0000F5">
                                <path d="M80 0v-160h800V0H80Zm160-320h56l312-311-29-29-28-28-311 312v56Zm-80 80v-170l448-447q11-11 25.5-17t30.5-6q16 0 31 6t27 18l55 56q12 11 17.5 26t5.5 31q0 15-5.5 29.5T777-687L330-240H160Zm560-504-56-56 56 56ZM608-631l-29-29-28-28 57 57Z" />
                            </svg>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="row borderbar"></div>
<div class="card mt-2 mb-2 text-center border-white">
    <div class="row">
        <div class="row">
            <h3 class="justify-conytent-center">Advertisement</h3>
            <a href="https://1040abroad.com/" target="_blank" class="text-white  mx-2" aria-label="Advertisement">
                <img src="https://tpc.googlesyndication.com/simgad/15465053050894477968" style="width:auto;" />
            </a>
        </div>
    </div>
</div>
<div class="row borderbar"></div>
<div class="row justify-content-center allfont">
    <div class="col-lg-12 col-md-12 col-sm-12">
        <h2 class="text-center text-decoration-underline">Most Popular</h2>
        <div class="row justify-content-center text-center">
            @foreach (var item in Model.Mostpopular)
            {
                <div class="col-12 col-md-4 mb-3">
                    <!-- Full width on small screens, 3 per row on medium+ -->
                    <partial name="_linkTextPartial" model="@item" />

                    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                    {
                        <a asp-action="Edit" asp-controller="Article" asp-route-id="@item.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#0000F5">
                                <path d="M200-200h57l391-391-57-57-391 391v57Zm-80 80v-170l528-527q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L290-120H120Zm640-584-56-56 56 56Zm-141 85-28-29 57 57-29-28Z" />
                            </svg>
                        </a>
                        <a asp-action="Delete" asp-controller="Article" asp-route-id="@item.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#5D0E07">
                                <path d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z" />
                            </svg>
                        </a>
                    }
                    @if (User.IsInRole("Writer"))
                    {
                        <a class="dropdown-item" asp-area="" asp-controller="Article" asp-action="EditAsWriter" asp-route-id="@item.Id">
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#0000F5">
                                <path d="M80 0v-160h800V0H80Zm160-320h56l312-311-29-29-28-28-311 312v56Zm-80 80v-170l448-447q11-11 25.5-17t30.5-6q16 0 31 6t27 18l55 56q12 11 17.5 26t5.5 31q0 15-5.5 29.5T777-687L330-240H160Zm560-504-56-56 56 56ZM608-631l-29-29-28-28 57 57Z" />
                            </svg>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>


<div class="row borderbar"></div>
<div class="container">
    <!-- Cookie Consent Popup -->
    @if (!ViewBag.HasConsented)
    {
        <div id="cookieConsentPopup" class="cookie-popup">
            <div class="cookie-banner">
                <p>We use cookies to improve your experience.</p>
                <form method="post" asp-controller="Home" asp-action="AcceptCookies" style="display:inline;">
                    <button type="submit" class="btn btn-primary">Accept</button>
                </form>
                <form method="post" asp-controller="Home" asp-action="DeclineCookies" style="display:inline;">
                    <button type="submit" class="btn btn-danger">Decline</button>
                </form>
            </div>
        </div>
    }

    <!-- Display TempData Message -->
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-warning">@TempData["Message"]</div>
    }
</div>

<style>
    .cookie-popup {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background-color: #333;
        color: white;
        padding: 10px;
        text-align: center;
        z-index: 9999;
    }

        .cookie-popup button {
            background-color: #4CAF50;
            color: white;
            border: none;
            padding: 10px 20px;
            cursor: pointer;
        }

            .cookie-popup button:hover {
                background-color: #45a049;
            }

    .alert {
        margin-top: 20px;
    }
</style>

<style>

    .borderbar{
        border-bottom: 1px solid black;
    }

    .electricity{
        color:black;
        margin-top: 20px;
        margin-bottom: 20px;
        background-color:white;
        text-align:center;    
    }

</style>




