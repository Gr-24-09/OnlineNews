@model IEnumerable<OnlineNews.Models.Database.Article>


@{
    ViewData["Title"] = "Home Page";
}


<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="row">
            @foreach (var item in Model)
            { 
             <div class="col-3 m-3">
                <partial name="_ArticlePartial" model="item"/>
             </div>

            }
        </div>
    </div>
</div>


