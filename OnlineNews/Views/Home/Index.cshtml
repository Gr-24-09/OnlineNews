@model OnlineNews.Models.FrontPageViewModel


@{
    ViewData["Title"] = "Home page";
}

<br />
<br />
<h2 style="text-align:center;text-decoration:underline;">Latest News</h2>
<br />
<div class="row"></div>
<div class="row justify-content-center allfont">
    <div class="col-lg-3 col-md-3 col-sm-12">
        @foreach (var item in Model.SomeLatestNews.Skip(1).Take(3))
