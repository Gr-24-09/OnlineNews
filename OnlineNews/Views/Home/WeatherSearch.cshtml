@model OnlineNews.Models.API.WeatherForecast


@{
    ViewData["Title"] = "Weather Search";
}



<h2>Search Weather by City</h2>

<!-- Search form to enter city name -->
<form method="get" asp-controller="Home" asp-action="WeatherSearch">
    <input type="text" name="city" placeholder="Enter city name" value="@ViewData["City"]" required />
    <button class="btn btn-primary"type="submit">Search</button>
</form>

<!-- Display Weather Data -->
@if (Model != null)
{
    <div class="row">
        <div class="col-8">
            <div class="row weatherbtn">
                <h3>Weather in @Model.city</h3>
                <p><strong>Summary:</strong> @Model.summary</p>
                <p><strong>Temperature:</strong> @Model.temperatureC °C / @Model.temperatureF °F</p>
                <p><strong>Humidity:</strong> @Model.humidity%</p>
                <p><strong>Wind Speed:</strong> @Model.windSpeed km/h</p>
                <p><strong>Date:</strong> @Model.date.ToString("MMMM dd, yyyy")</p>
                @if (Model.icon != null)
                {
                    <img src="@Model.icon.url" alt="Weather icon" />
                }
                else
                {
                    <p>No weather data available. Please enter a valid city.</p>
                }
            </div>
        </div>
    </div>
}


<style>
    .weatherbtn
    {
        background-color: #7e82aa;
        color:black;
        font-size:25px;
        text-align:center;
        height:90px;
    }

</style>