@using Microsoft.AspNetCore.Identity
@using OnlineNews.Models.Database
@using OnlineNews.Service
@inject IAdminService _adminService

@model IEnumerable<User>





<h3> - List of all users - </h3>
<table class="table"> 
    <thead>
        <tr>
            <th>
                Username
            </th>
            <th>
                Email
            </th>
            <th>
                First Name
            </th>
            <th>
                Last Name
            </th>
            <th>
                Role
            </th>
            <th>
                ChangeRole
            </th>

        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {

            <tr>

                <td>
                    @item.UserName
                </td>
                <td>
                    @item.Email
                </td>
                <td>
                    @item.FirstName
                </td>
                <td>
                    @item.LastName
                </td>
                <td>
                    @{
                        string role = await _adminService.FindRole(item);
                    }
                    <span>@role</span>
                </td>
                <td>
                        <a asp-controller="Admin" asp-action="AddRoleToUser" asp-route-userId="@item.Id"> Add</a>
                </td>
            </tr>

        }

        </tbody>
    </table>
