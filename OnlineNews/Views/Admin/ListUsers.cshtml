@using Microsoft.AspNetCore.Identity
@using OnlineNews.Models.Database
@model IEnumerable<User>



<h3> - List of all users - </h3>
<table class="table"> 
    <thead>
        <tr>
            <th>
                Username
            </th>
            <th>
                Email
            </th>
            <th>
                First Name
            </th>
            <th>
                Last Name
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
            
            <tr>

                <td>
                    @item.UserName
                </td>
                <td>
                    @item.Email
                </td>
                <td>
                    @item.FirstName
                </td>
                <td>
                    @item.LastName
                </td>

            </tr>

        }

        </tbody>
    </table>
