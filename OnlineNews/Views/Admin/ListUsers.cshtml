@using Microsoft.AspNetCore.Identity
@using OnlineNews.Models.Database
@using OnlineNews.Service
@inject IAdminService _adminService

@model IEnumerable<UserWithRolesVM>





<h3> - List of all users - </h3>
<table class="table"> 
    <thead>
        <tr>
            <th>
                Username
            </th>
            <th>
                Email
            </th>
            <th>
                First Name
            </th>
            <th>
                Last Name
            </th>
            <th>
                Role
            </th>
            <th>
                ChangeRole
            </th>

        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {

            <tr>

                <td>
                    @item.User.UserName
                </td>
                <td>
                    @item.User.Email
                </td>
                <td>
                    @item.User.FirstName
                </td>
                <td>
                    @item.User.LastName
                </td>
                <td>
                   @*  @{
                        string role = await _adminService.FindRole(item);
                    } *@
                    @* <span>@role</span> *@

                    @(item.Roles.Any() ? string.Join(", ", item.Roles) : "No roles assigned")

                </td>
                
                    
                <td>
                    <form asp-controller="Admin" asp-action="AddRoleToUser" method="post" >
                        <input type="hidden" name="userId" value="@item.User.Id" />
                        <select name="role" id="Roles">
                            @foreach(var myRole in ViewBag.Roles)
                                {

                                    @* <option value="@myRole.Id"> @myRole.Name </option> *@
                                    <option value="@myRole.Name"> @myRole.Name </option>

                                }

                        </select>
                        <button type="submit" class="btn btn-primary">Assign Role</button>
                    </form>


                </td>

                <td>
                    <form asp-action="RemoveRoleFromUser" asp-controller="Admin" method="post" style="display:inline;">
                        <input type="hidden" name="userId" value="@item.User.Id" />
                        <button type="submit" class="btn btn-danger">Remove Role</button>
                    </form>
                </td>
            

                
            </tr>

        }

        </tbody>
    </table>

<h3> - Active users - </h3>
<table class="table">
    <thead>
        <tr>
            <th>
                Username
            </th>
            <th>
                Email
            </th>
            <th>
                First Name
            </th>
            <th>
                Last Name
            </th>
            <th>
                Active
            </th>

            <th>Toggle Status</th>

        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model.Where(x => x.User.IsActive == true))
        {

            <tr>
                <td>
                    @item.User.UserName
                </td>
                <td>
                    @item.User.Email
                </td>
                <td>
                    @item.User.FirstName
                </td>
                <td>
                    @item.User.LastName
                </td>
                <td>
                    @item.User.IsActive
                </td>

                <td>
                    <a class="btn btn-warning" asp-controller="Admin" asp-action="ToggleUserStatus" asp-route-userId="@item.User.Id">
                        Deactivate
                    </a>
                </td>

            </tr>

        }

    </tbody>

</table>
<h3> - Inactive users - </h3>
<table class="table">
    <thead>
        <tr>
            <th>
                Username
            </th>
            <th>
                Email
            </th>
            <th>
                First Name
            </th>
            <th>
                Last Name
            </th>
            <th>
                Active
            </th>

            <th>Toggle Status</th> 

        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model.Where(x => x.User.IsActive == false))
        {

            <tr>
                <td>
                    @item.User.UserName
                </td>
                <td>
                    @item.User.Email
                </td>
                <td>
                    @item.User.FirstName
                </td>
                <td>
                    @item.User.LastName
                </td>
                <td>
                    @item.User.IsActive
                </td>

                <td>
                    <a class="btn btn-success" asp-controller="Admin" asp-action="ToggleUserStatus" asp-route-userId="@item.User.Id">
                        Activate
                    </a>
                </td>

            </tr>

        }

        

    </tbody>

</table>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>
    <body>

        <canvas id="myChart" style="width:100%;max-width:600px justify-content: center;"></canvas>

        <script>
        const xValues = ["None Subscribers", "Basic Subscribers", "Premium Subscribers"];
              const yValues = [44, 24, 15];
              const barColors = [
                "#b91d47",
                "#00aba9",
                "#2b5797",
                "#e8c3b9",
                "#1e7145"
              ];

              new Chart("myChart", {
                type: "doughnut",
                data: {
                  labels: xValues,
                  datasets: [{
                    backgroundColor: barColors,
                    data: yValues
                  }]
                },
                options: {
                  title: {
                    display: true,
                    text: "Subscribers and none subscribers"
                  }
                }
              });
        </script>
    </body>

    <body>


    @* for the charts *@


    <h2>Subscription Statistics</h2>

    <canvas id="subscriptionChart" width="400" height="400" style="justify-content: center;"></canvas>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            fetch('@Url.Action("GetSubscriptionCounts", "Subscription")')
                .then(response => response.json())
                .then(data => {
                    var ctx = document.getElementById('subscriptionChart').getContext('2d');
                    var subscriptionChart = new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: ['No Subscription', 'Basic Subscription', 'Premium Subscription'],
                            datasets: [{
                                data: [data.NoSubscription, data.BasicSubscription, data.PremiumSubscription],
                                backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56']
                            }]
                        },
                        options: {
                            responsive: true,
                            legend: {
                                position: 'top',
                            },
                            title: {
                                display: true,
                                text: 'User Subscriptions'
                            }
                        }
                    });
                });
        });
    </script>

    </body>
