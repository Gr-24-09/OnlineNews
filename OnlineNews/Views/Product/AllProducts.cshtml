@model IEnumerable<OnlineNews.Models.Product>


@{
    ViewData["Title"] = "AllProducts";
    Layout = "~/Views/Shared/_ProductLayout.cshtml";
}


<div class="row justify-content-center allfont mt-0">
    <div class="col-lg-12 col-md-12 col-sm-12">
        <div class="row justify-content-center">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-3 mb-3">
                    <div class="card border-white mb-1">
                        <a asp-action="Details" asp-controller="Product" asp-route-id="@item.Id">
                            <img src="@item.ImageUrl" class="card-img-top img-fluid" style="width:270px;height:150px" />
                        </a>
                        <div class="card-body">
                            <h6 class="card-title"><b>@item.Name</b></h6>
                            <p><b>Price:</b> @item.Price kr</p>
                            <p>Only @item.StockQuantity left in stock</p>
                        </div>
                    </div>
                    <a asp-action="AddProductToCart" asp-controller="Cart" asp-route-id="@item.Id">Add To Cart</a>
                    <a asp-action="Edit" asp-controller="Product" asp-route-id="@item.Id">Edit</a>
                    <a asp-action="Details" asp-controller="Product" asp-route-id="@item.Id">Details</a>
                    <a asp-action="Delete" asp-controller="Product" asp-route-id="@item.Id">Delete</a>
                </div>
            }
        </div>
    </div>
</div>
